datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto, citext, pg_trgm, unaccent]
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

enum ProductStatus {
  draft
  published
  archived
  out_of_stock
}

enum EventStatus {
  draft
  published
  cancelled
  completed
}

enum ProposalStatus {
  pending
  reviewed
  accepted
  declined
}

enum MediaType {
  image
  video
  three_d @map("3d")

  @@map("media_type_enum")
}

enum JobStatus {
  pending
  processing
  completed
  failed

  @@map("job_status_enum")
}

model Role {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String           @default("00000000-0000-0000-0000-000000000000") @map("tenant_id") @db.Uuid
  name        String           @unique @db.VarChar(100)
  description String?          @db.VarChar(255)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String           @default("00000000-0000-0000-0000-000000000000") @map("tenant_id") @db.Uuid
  name        String           @unique @db.VarChar(100)
  description String?          @db.VarChar(255)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id                  String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String                  @default("00000000-0000-0000-0000-000000000000") @map("tenant_id") @db.Uuid
  email               String                  @unique @db.Citext // Case-Insensitive Email Integrity
  passwordHash        String                  @map("password_hash") // TEXT type
  fullName            String                  @map("full_name")
  roleId              String                  @map("role_id") @db.Uuid
  isActive            Boolean                 @default(true) @map("is_active")
  
  -- Account Security Parameters
  lastLoginAt         DateTime?               @map("last_login_at")
  failedLoginAttempts Int                     @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime?               @map("locked_until")
  passwordChangedAt   DateTime                @default(now()) @map("password_changed_at")
  
  -- Universal extensible metadata
  metadata            Json                    @default("{}") @map("metadata")
  
  createdAt           DateTime                @default(now()) @map("created_at")
  updatedAt           DateTime                @updatedAt @map("updated_at")
  role                Role                    @relation(fields: [roleId], references: [id], onDelete: Restrict)
  
  auditLogs           AuditLog[]
  sessions            UserSession[]
  reviewedProposals   CollaborationProposal[] @relation("Reviewer")
  resetTokens         PasswordResetToken[]
  verifyTokens        EmailVerificationToken[]

  -- Traceability authorship relations
  createdCategories   Category[]              @relation("CategoryCreatedBy")
  updatedCategories   Category[]              @relation("CategoryUpdatedBy")
  createdProducts     Product[]               @relation("ProductCreatedBy")
  updatedProducts     Product[]               @relation("ProductUpdatedBy")
  createdEvents       Event[]                 @relation("EventCreatedBy")
  updatedEvents       Event[]                 @relation("EventUpdatedBy")
  createdSizes        Size[]                  @relation("SizeCreatedBy")
  updatedSizes        Size[]                  @relation("SizeUpdatedBy")
  createdStores       Store[]                 @relation("StoreCreatedBy")
  updatedStores       Store[]                 @relation("StoreUpdatedBy")
  createdJobs         BackgroundJob[]         @relation("JobCreatedBy")
  updatedJobs         BackgroundJob[]         @relation("JobUpdatedBy")
  createdRedirects    SlugRedirect[]          @relation("RedirectCreatedBy")
  updatedRedirects    SlugRedirect[]          @relation("RedirectUpdatedBy")
  
  -- Published trace audits
  publishedCategories CategoryTranslation[]   @relation("CategoryPublishedBy")
  publishedProducts   ProductTranslation[]    @relation("ProductPublishedBy")
  publishedEvents     EventTranslation[]      @relation("EventPublishedBy")

  -- Soft delete relations
  deletedCategories   Category[]              @relation("CategoryDeletedBy")
  deletedProducts     Product[]               @relation("ProductDeletedBy")
  deletedEvents       Event[]                 @relation("EventDeletedBy")
  deletedProposals    CollaborationProposal[] @relation("ProposalDeletedBy")

  @@map("users")
}

model UserSession {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @default("00000000-0000-0000-0000-000000000000") @map("tenant_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar(64) // Secure SHA-256 Hash
  ipAddress String?   @map("ip_address") @db.VarChar(45)
  userAgent String?   @map("user_agent") @db.Text
  revokedAt DateTime? @map("revoked_at") // Revocation timestamp support
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_sessions")
}

model RateLimit {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @default("00000000-0000-0000-0000-000000000000") @map("tenant_id") @db.Uuid
  ipAddress     String   @map("ip_address") @db.VarChar(45)
  endpoint      String   @db.VarChar(100)
  attempts      Int      @default(1)
  lastAttemptAt DateTime @default(now()) @map("last_attempt_at")

  @@unique([ipAddress, endpoint])
  @@map("rate_limits")
}

model PasswordResetToken {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String   @default("00000000-0000-0000-0000-000000000000") @map("tenant_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  tokenHash  String   @unique @map("token_hash") @db.VarChar(64)
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String   @default("00000000-0000-0000-0000-000000000000") @map("tenant_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  tokenHash  String   @unique @map("token_hash") @db.VarChar(64)
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verification_tokens")
}

-- Partitioned Table structure mapping (Composite ID + CreatedAt Primary Key)
model AuditLog {
  id        String   @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @default("00000000-0000-0000-0000-000000000000") @map("tenant_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String
  tableName String   @map("table_name")
  recordId  String   @map("record_id") @db.Uuid
  oldData   Json?    @map("old_data")
  newData   Json?    @map("new_data")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  requestId String?  @map("request_id") @db.Uuid // Distributed Request tracer
  createdAt DateTime @default(now()) @map("created_at")
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@id([id, createdAt])
  @@index([tableName, recordId])
  @@map("audit_logs")
}

model Category {
  id           String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String                @default("00000000-0000-0000-0000-000000000000") @map("tenant_id") @db.Uuid
  parentId     String?               @map("parent_id") @db.Uuid
  imageUrl     String?               @map("image_url") @db.VarChar(512)
  sortOrder    Int                   @default(0) @map("sort_order")
  isActive     Boolean               @default(true) @map("is_active")
  
  -- Traceability fields
  createdBy    String?               @map("created_by") @db.Uuid
  updatedBy    String?               @map("updated_by") @db.Uuid
  creator      User?                 @relation("CategoryCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  updater      User?                 @relation("CategoryUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)
  
  -- Soft Deletes
  deletedAt    DateTime?             @map("deleted_at")
  deletedBy    String?               @map("deleted_by") @db.Uuid
  deleter      User?                 @relation("CategoryDeletedBy", fields: [deletedBy], references: [id], onDelete: SetNull)
  
  -- Extensible JSONB
  metadata     Json                  @default("{}") @map("metadata")
  
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")
  parent       Category?             @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children     Category[]            @relation("CategoryHierarchy")
  translations CategoryTranslation[]
  products     ProductCategoryMap[]

  @@map("categories")
}

model CategoryTranslation {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId      String    @map("category_id") @db.Uuid
  languageCode    String    @map("language_code") @db.VarChar(10)
  name            String    @db.VarChar(255)
  slug            String    @db.VarChar(255)
  
  -- Advanced SEO Parameters
  canonicalUrl    String?   @map("canonical_url") @db.VarChar(512)
  ogImageUrl      String?   @map("og_image_url") @db.VarChar(512)
  
  metaTitle       String?   @map("meta_title") @db.VarChar(255)
  metaDescription String?   @map("meta_description") @db.VarChar(512)
  
  -- Content publishing audits
  publishedAt     DateTime? @map("published_at") // Scheduled/Historical Translation release
  publishedBy     String?   @map("published_by") @db.Uuid
  publisher       User?     @relation("CategoryPublishedBy", fields: [publishedBy], references: [id], onDelete: SetNull)
  
  category        Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, languageCode])
  @@unique([slug, languageCode])
  @@index([slug, languageCode])
  @@map("category_translations")
}

model Product {
  id           String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String               @default("00000000-0000-0000-0000-000000000000") @map("tenant_id") @db.Uuid
  sku          String               @unique @db.VarChar(100)
  status       ProductStatus        @default(draft)
  isFeatured   Boolean              @default(false) @map("is_featured")
  sortOrder    Int                  @default(0) @map("sort_order")
  
  -- Traceability fields
  createdBy    String?              @map("created_by") @db.Uuid
  updatedBy    String?              @map("updated_by") @db.Uuid
  creator      User?                @relation("ProductCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  updater      User?                @relation("ProductUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)
  
  -- Soft Deletes
  deletedAt    DateTime?            @map("deleted_at")
  deletedBy    String?              @map("deleted_by") @db.Uuid
  deleter      User?                @relation("ProductDeletedBy", fields: [deletedBy], references: [id], onDelete: SetNull)
  
  -- Extensible JSONB
  metadata     Json                 @default("{}") @map("metadata")
  
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")
  translations ProductTranslation[]
  media        ProductMedia[]
  variants     ProductVariant[]
  categories   ProductCategoryMap[]

  @@map("products")
}

model ProductTranslation {
  id               String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId        String                 @map("product_id") @db.Uuid
  languageCode     String                 @map("language_code") @db.VarChar(10)
  title            String                 @db.VarChar(255)
  slug             String                 @db.VarChar(255)
  description      String                 @db.Text
  shortDescription String?                @map("short_description") @db.VarChar(512)
  
  -- Advanced SEO Parameters
  canonicalUrl     String?                @map("canonical_url") @db.VarChar(512)
  ogImageUrl       String?                @map("og_image_url") @db.VarChar(512)
  
  metaTitle        String?                @map("meta_title") @db.VarChar(255)
  metaDescription  String?                @map("meta_description") @db.VarChar(512)
  metaKeywords     String?                @map("meta_keywords") @db.VarChar(512)
  
  -- Content publishing audits
  publishedAt      DateTime?              @map("published_at") // Scheduled/Historical Translation release
  publishedBy      String?                @map("published_by") @db.Uuid
  publisher        User?                  @relation("ProductPublishedBy", fields: [publishedBy], references: [id], onDelete: SetNull)
  
  -- Native Full-Text search vector compiled at DB layer
  searchVector     Unsupported("tsvector")? @map("search_vector")
  product          Product                @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, languageCode])
  @@unique([slug, languageCode])
  @@index([slug, languageCode])
  @@map("product_translations")
}

model ProductMedia {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String    @map("product_id") @db.Uuid
  url       String    @db.VarChar(512)
  mediaType MediaType @default(image) @map("media_type") // Strict Type Safety Enum
  altText   String?   @map("alt_text") @db.VarChar(255)
  sortOrder Int       @default(0) @map("sort_order")
  
  -- CDN aspect-ratio & optimization dimensions preventing CLS
  width     Int?
  height    Int?
  mimeType  String?   @map("mime_type") @db.VarChar(100)
  fileSize  Int?      @map("file_size")
  
  -- Media Deduplication SHA-256 Hash
  fileHash  String?   @map("file_hash") @db.VarChar(64)
  
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([sortOrder])
  @@map("product_media")
}

model SlugRedirect {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String   @default("00000000-0000-0000-0000-000000000000") @map("tenant_id") @db.Uuid
  entityType String   @map("entity_type") @db.VarChar(50)
  entityId   String   @map("entity_id") @db.Uuid
  oldSlug    String   @map("old_slug") @db.VarChar(255)
  newSlug    String   @map("new_slug") @db.VarChar(255)
  statusCode Int      @default(301) @map("status_code")
  
  -- Traceability fields
  createdBy  String?  @map("created_by") @db.Uuid
  updatedBy  String?  @map("updated_by") @db.Uuid
  creator    User?    @relation("RedirectCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  updater    User?    @relation("RedirectUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)
  
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("slug_redirects")
}

model Size {
  id        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String           @default("00000000-0000-0000-0000-000000000000") @map("tenant_id") @db.Uuid
  name      String           @db.VarChar(50)
  type      String           @db.VarChar(50)
  
  -- Traceability fields
  createdBy String?          @map("created_by") @db.Uuid
  updatedBy String?          @map("updated_by") @db.Uuid
  creator   User?            @relation("SizeCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  updater   User?            @relation("SizeUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)
  
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  variants  ProductVariant[]

  @@unique([name, type])
  @@index([type])
  @@map("sizes")
}

model ProductVariant {
  id              String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String                   @default("00000000-0000-0000-0000-000000000000") @map("tenant_id") @db.Uuid
  productId       String                   @map("product_id") @db.Uuid
  sizeId          String                   @map("size_id") @db.Uuid
  sku             String                   @unique @db.VarChar(100)
  
  -- Price parameters shifted to variant level
  price           Decimal                  @db.Decimal(12, 2)
  compareAtPrice  Decimal?                 @map("compare_at_price") @db.Decimal(12, 2)
  
  -- Extensible JSONB
  metadata        Json                     @default("{}") @map("metadata")
  
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")
  product         Product                  @relation(fields: [productId], references: [id], onDelete: Cascade)
  size            Size                     @relation(fields: [sizeId], references: [id], onDelete: Restrict)
  stores          VariantStoreVisibility[]

  @@unique([productId, sizeId])
  @@map("product_variants")
}

model Store {
  id        String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String                   @default("00000000-0000-0000-0000-000000000000") @map("tenant_id") @db.Uuid
  code      String                   @unique @db.VarChar(50) // ERP branch system code
  name      String                   @unique @db.VarChar(255)
  address   String?                  @db.Text
  isActive  Boolean                  @default(true) @map("is_active")
  
  -- Extensible JSONB
  metadata  Json                     @default("{}") @map("metadata")
  
  -- Traceability fields
  createdBy String?                  @map("created_by") @db.Uuid
  updatedBy String?                  @map("updated_by") @db.Uuid
  creator   User?                    @relation("StoreCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  updater   User?                    @relation("StoreUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)
  
  createdAt DateTime                 @default(now()) @map("created_at")
  updatedAt DateTime                 @updatedAt @map("updated_at")
  variants  VariantStoreVisibility[]

  @@map("stores")
}

-- Renamed to resolve inventory count confusion (strictly represents show-room showcase visibility mapping)
model VariantStoreVisibility {
  variantId   String         @map("variant_id") @db.Uuid
  storeId     String         @map("store_id") @db.Uuid
  isAvailable Boolean        @default(true) @map("is_available")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  store       Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@id([variantId, storeId])
  @@map("variant_store_visibility")
}

model ProductCategoryMap {
  productId  String   @map("product_id") @db.Uuid
  categoryId String   @map("category_id") @db.Uuid
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@map("product_category_map")
}

model Event {
  id           String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String             @default("00000000-0000-0000-0000-000000000000") @map("tenant_id") @db.Uuid
  eventDate    DateTime           @map("event_date")
  location     String             @db.VarChar(255)
  imageUrl     String             @map("image_url") @db.VarChar(512)
  status       EventStatus        @default(draft)
  sortOrder    Int                @default(0) @map("sort_order")
  
  -- Traceability fields
  createdBy    String?            @map("created_by") @db.Uuid
  updatedBy    String?            @map("updated_by") @db.Uuid
  creator      User?              @relation("EventCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  updater      User?              @relation("EventUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)
  
  -- Soft Deletes
  deletedAt    DateTime?          @map("deleted_at")
  deletedBy    String?            @map("deleted_by") @db.Uuid
  deleter      User?              @relation("EventDeletedBy", fields: [deletedBy], references: [id], onDelete: SetNull)
  
  -- Extensible JSONB
  metadata     Json               @default("{}") @map("metadata")
  
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")
  translations EventTranslation[]

  @@map("events")
}

model EventTranslation {
  id              String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId         String                   @map("event_id") @db.Uuid
  languageCode    String                   @map("language_code") @db.VarChar(10)
  title           String                   @db.VarChar(255)
  slug            String                   @db.VarChar(255)
  description     String                   @db.Text
  category        String                   @db.VarChar(100)
  
  -- Advanced SEO Parameters
  canonicalUrl    String?                  @map("canonical_url") @db.VarChar(512)
  ogImageUrl      String?                  @map("og_image_url") @db.VarChar(512)
  
  metaTitle       String?                  @map("meta_title") @db.VarChar(255)
  metaDescription String?                  @map("meta_description") @db.VarChar(512)
  
  -- Content publishing audits
  publishedAt     DateTime?                @map("published_at") // Scheduled/Historical Translation release
  publishedBy     String?                  @map("published_by") @db.Uuid
  publisher       User?                    @relation("EventPublishedBy", fields: [publishedBy], references: [id], onDelete: SetNull)
  
  -- Native Full-Text search vector compiled at DB layer
  searchVector    Unsupported("tsvector")? @map("search_vector")
  event           Event                    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, languageCode])
  @@unique([slug, languageCode])
  @@index([slug, languageCode])
  @@map("event_translations")
}

model CollaborationProposal {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String         @default("00000000-0000-0000-0000-000000000000") @map("tenant_id") @db.Uuid
  fullName      String         @map("full_name") @db.VarChar(255)
  email         String         @db.VarChar(255)
  phone         String         @db.VarChar(50)
  proposalText  String         @map("proposal_text") @db.Text
  attachmentUrl String?        @map("attachment_url") @db.VarChar(512)
  status        ProposalStatus @default(pending)
  
  -- Soft Deletes
  deletedAt     DateTime?      @map("deleted_at")
  deletedBy     String?        @map("deleted_by") @db.Uuid
  deleter       User?          @relation("ProposalDeletedBy", fields: [deletedBy], references: [id], onDelete: SetNull)
  
  submittedAt   DateTime       @default(now()) @map("submitted_at")
  reviewedAt    DateTime?      @map("reviewed_at")
  reviewedById  String?        @map("reviewed_by") @db.Uuid
  reviewer      User?          @relation("Reviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@map("collaboration_proposals")
}

model BackgroundJob {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @default("00000000-0000-0000-0000-000000000000") @map("tenant_id") @db.Uuid
  queueName    String    @default("default") @map("queue_name") @db.VarChar(100)
  payload      Json      @map("payload")
  attempts     Int       @default(0) @map("attempts")
  status       JobStatus @default(pending) @map("status") // Enforced Type-Safe enum
  errorMessage String?   @map("error_message") @db.Text
  runAt        DateTime  @default(now()) @map("run_at")
  
  -- Traceability fields
  createdBy    String?   @map("created_by") @db.Uuid
  updatedBy    String?   @map("updated_by") @db.Uuid
  creator      User?     @relation("JobCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  updater      User?     @relation("JobUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)
  
  createdAt    DateTime  @default(now()) @map("created_at")

  @@map("background_jobs")
}
